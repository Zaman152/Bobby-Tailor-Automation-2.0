# ──────────────────────────────────────────────────────────────────────
# StackCT Credentials
# ──────────────────────────────────────────────────────────────────────
STACKCT_EMAIL=your_stackct_login_email@example.com
STACKCT_PASSWORD=your_stackct_password

# ──────────────────────────────────────────────────────────────────────
# Anthropic API Configuration
# ──────────────────────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Default model used for most sheets (Haiku = cheapest, Sonnet = better at tables)
#   claude-haiku-4-5   → $1/$5  per 1M tokens
#   claude-sonnet-4-6  → $3/$15 per 1M tokens
#   claude-opus-4-7    → $5/$25 per 1M tokens
CLAUDE_MODEL=claude-haiku-4-5

# Smart-routing: model auto-selected for sheets whose name contains
# SCHEDULE/PANEL/RISER/EQUIPMENT or matches an E/M/P sheet code
CLAUDE_MODEL_SCHEDULES=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────
# Browser Settings
# ──────────────────────────────────────────────────────────────────────
# Run browser headless (true for server deployments, false to watch it work)
HEADLESS=true

# Canvas stability before screenshot (seconds; increase on slow VPS)
CANVAS_STABILITY_TIMEOUT=15
CANVAS_STABILITY_CHECKS=2

# ──────────────────────────────────────────────────────────────────────
# Output Configuration
# ──────────────────────────────────────────────────────────────────────
# Where reports and screenshots are written
OUTPUT_DIR=./output

# Hours before StackCT project/plan catalog is considered stale (default 24)
STACKCT_CACHE_TTL_HOURS=24

# ──────────────────────────────────────────────────────────────────────
# Schedule Configuration
# ──────────────────────────────────────────────────────────────────────
# Cron expression for automated runs (default: daily at 8am)
# Format: minute hour day month weekday
# Examples:
#   0 8 * * *     → daily at 8:00 AM
#   0 */6 * * *   → every 6 hours
#   0 0 * * 1     → every Monday at midnight
RUN_SCHEDULE=0 8 * * *

# ──────────────────────────────────────────────────────────────────────
# Application Authentication (Phase 12)
# ──────────────────────────────────────────────────────────────────────
# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. App will not start without this.
SECRET_KEY=your-random-secret-key-here

# Admin login credentials — set by running: python seed_admin.py
# Never put plaintext password here — only the bcrypt hash
ADMIN_EMAIL=admin@bobbytailor.com
ADMIN_PASSWORD_HASH=$2b$12$...bcrypt-hash-from-seed_admin.py...

# Set to "development" locally to disable Secure cookie flag (HTTP)
# Leave unset in production (defaults to secure mode)
# FLASK_ENV=development

# Rate limit storage — memory:// is single-process only (fine for dev)
# On gunicorn with multiple workers, use Redis so limits are shared:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
RATE_LIMIT_STORAGE_URI=memory://
